generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SubscriptionStatus {
  none
  active
  cancelling
  cancelled
  past_due
}

enum SubscriptionTier {
  none
  basic
  multi
  agent @map("bulk")
}

enum FilingStatus {
  outstanding
  pending
  submitted
  accepted
  rejected
  failed
  filed_elsewhere
}

enum FilingType {
  accounts
  ct600
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  passwordHash       String
  name               String
  stripeCustomerId   String?
  subscriptionStatus SubscriptionStatus @default(none)
  subscriptionTier   SubscriptionTier   @default(none)
  subscriptionPeriodStart DateTime?
  filingAsAgent      Boolean            @default(false)
  remindersMuted     Boolean            @default(false)
  isAdmin            Boolean            @default(false)
  emailVerified      DateTime?
  calendarFeedToken  String?            @unique
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  companies          Company[]
  resetTokens        PasswordResetToken[]
  verificationTokens EmailVerificationToken[]
  pendingEmailChange PendingEmailChange?
  review             Review?
}

model Company {
  id                        String     @id @default(cuid())
  userId                    String
  companyName               String
  companyRegistrationNumber String
  uniqueTaxReference        String?
  registeredForCorpTax      Boolean    @default(false)
  shareCapital              Int        @default(0)
  companyAuthCode           String?
  accountingPeriodStart     DateTime
  accountingPeriodEnd       DateTime
  dateOfCreation            DateTime?
  accountsDueOn             DateTime?
  companyStatus             String?
  companyType               String?
  registeredAddress         String?
  sicCodes                  String?
  ardMonth                  Int?
  ardDay                    Int?
  ctapStartDate             DateTime?
  ardChangeDetected         Boolean    @default(false)
  ardChangeDetectedAt       DateTime?
  newArdMonth               Int?
  newArdDay                 Int?
  deletedAt                 DateTime?
  createdAt                 DateTime   @default(now())
  updatedAt                 DateTime   @updatedAt
  user                      User       @relation(fields: [userId], references: [id])
  periods                   Period[]
  filings                   Filing[]
  notifications             Notification[]

  @@unique([userId, companyRegistrationNumber])
}

model Period {
  id               String    @id @default(cuid())
  companyId        String
  periodStart      DateTime
  periodEnd        DateTime
  accountsDeadline DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  company          Company   @relation(fields: [companyId], references: [id])
  filings          Filing[]

  @@unique([companyId, periodStart, periodEnd])
}

model Filing {
  id               String       @id @default(cuid())
  periodId         String?
  companyId        String
  filingType       FilingType
  periodStart      DateTime
  periodEnd        DateTime
  startDate        DateTime?
  endDate          DateTime?
  status           FilingStatus @default(pending)
  accountsDeadline DateTime?
  ct600Deadline    DateTime?
  deadline         DateTime?
  suppressedAt     DateTime?
  correlationId    String?      @map("hmrcCorrelationId")
  responsePayload  String?      @map("hmrcResponsePayload")
  irmark           String?
  pollInterval     Int?
  submissionNumber String?
  submittedAt      DateTime?
  confirmedAt      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  period           Period?      @relation(fields: [periodId], references: [id])
  company          Company      @relation(fields: [companyId], references: [id])
  notifications    Notification[]

  @@unique([companyId, periodStart, periodEnd, filingType])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model PendingEmailChange {
  id        String    @id @default(cuid())
  userId    String    @unique
  newEmail  String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  companyId String
  filingId  String
  type      String
  sentAt    DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id])
  filing    Filing   @relation(fields: [filingId], references: [id])
}

model Review {
  id        String    @id @default(cuid())
  userId    String?   @unique
  rating    Int
  text      String?
  name      String
  verified  Boolean   @default(false)
  approved  Boolean   @default(false)
  hiddenAt  DateTime?
  createdAt DateTime  @default(now())
  user      User?     @relation(fields: [userId], references: [id])
}

model ContactMessage {
  id        String    @id @default(cuid())
  name      String
  email     String
  message   String
  readAt    DateTime?
  createdAt DateTime  @default(now())
}
