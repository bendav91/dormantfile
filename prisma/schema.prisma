generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SubscriptionStatus {
  none
  active
  cancelled
  past_due
}

enum FilingStatus {
  pending
  submitted
  polling_timeout
  accepted
  rejected
  failed
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  passwordHash       String
  name               String
  stripeCustomerId   String?
  subscriptionStatus SubscriptionStatus @default(none)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  company            Company?
}

model Company {
  id                        String     @id @default(cuid())
  userId                    String     @unique
  companyName               String
  companyRegistrationNumber String
  uniqueTaxReference        String
  accountingPeriodStart     DateTime
  accountingPeriodEnd       DateTime
  createdAt                 DateTime   @default(now())
  updatedAt                 DateTime   @updatedAt
  user                      User       @relation(fields: [userId], references: [id])
  filings                   Filing[]
  reminders                 Reminder[]
}

model Filing {
  id                  String       @id @default(cuid())
  companyId           String
  periodStart         DateTime
  periodEnd           DateTime
  status              FilingStatus @default(pending)
  hmrcCorrelationId   String?
  hmrcResponsePayload String?
  submittedAt         DateTime?
  confirmedAt         DateTime?
  createdAt           DateTime     @default(now())
  company             Company      @relation(fields: [companyId], references: [id])

  @@unique([companyId, periodStart, periodEnd])
}

model Reminder {
  id                 String    @id @default(cuid())
  companyId          String
  filingDeadline     DateTime
  remindersSent      Int       @default(0)
  lastReminderSentAt DateTime?
  nextReminderAt     DateTime?
  createdAt          DateTime  @default(now())
  company            Company   @relation(fields: [companyId], references: [id])
}
