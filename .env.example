# Database (Prisma Postgres via Vercel Marketplace)
# Auto-provisioned by the Prisma integration on Vercel.
# For local development, point to your local database.
POSTGRES_URL="postgresql://user:password@localhost:5432/nil_ct600"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secret-here"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID_BASIC="price_..."
STRIPE_PRICE_ID_MULTI="price_..."
STRIPE_PRICE_ID_AGENT="price_..."

# Resend
RESEND_API_KEY="re_..."

# HMRC
HMRC_VENDOR_ID="your-vendor-id"
HMRC_SENDER_ID="your-sender-id"
HMRC_SENDER_PASSWORD="your-sender-password"
HMRC_ENDPOINT="https://test-transaction-engine.tax.service.gov.uk/submission"

# Cron
CRON_SECRET="generate-a-secret-here"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Company Information
COMPANIES_HOUSE_API_KEY="your-companies-house-api-key"
COMPANY_INFORMATION_API_ENDPOINT="https://api-sandbox.company-information.service.gov.uk"

# Companies House (Software Filing)
COMPANIES_HOUSE_PRESENTER_ID="your-presenter-id"
COMPANIES_HOUSE_PRESENTER_AUTH="your-presenter-auth"
COMPANIES_HOUSE_FILING_ENDPOINT="https://xmlgw.companieshouse.gov.uk/v1-0/xmlgw/Gateway"

# Launch mode (e.g., "preview", "production")
NEXT_PUBLIC_LAUNCH_MODE="preview"
